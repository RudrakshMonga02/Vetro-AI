# Copy this file to .env and replace the placeholders with real values.
# Do not commit your local .env file.

GEMINI_API_KEY=

# Only needed if you're building DATABASE_URL below against a Supabase
# Postgres project -- not read directly by the app.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Real Postgres connection string (local or Supabase). Required when
# DATA_BACKEND=postgres. See README.md "Setup" for the format.
DATABASE_URL=postgresql+psycopg2://<user>:<pass>@<host>:5432/ksp_datathon

# postgres = local/Supabase dev (default). catalyst = Catalyst Data Store,
# once its tables exist -- see README.md "Repository pattern" section.
DATA_BACKEND=postgres

# catalyst_quickml = Catalyst QuickML LLM Serving (this project's actual
# default -- see infrastructure/llm/catalyst_quickml_provider.py), needs
# CATALYST_AUTH, QUICKML_ENDPOINT_URL, QUICKML_MODEL, and
# X_ZOHO_CATALYST_ORG_ID below all set. gemini = direct Gemini calls,
# a safe fallback for local dev if you haven't done the Catalyst OAuth
# setup yet -- Python-level default if this var is unset entirely.
LLM_BACKEND=catalyst_quickml

# Shared Catalyst OAuth credentials -- a JSON string (single line) with a
# Zoho self-client's OAuth credentials:
#   {"client_id":"...","client_secret":"...","refresh_token":"..."}
# Register a Self Client at your region's API Console (e.g.
# api-console.zoho.in) -- NOT `catalyst token:generate`, which produces a
# different, CLI-only credential type that doesn't fit this shape. Used
# by both catalyst_quickml_provider.py and catalyst_cache_provider.py, so
# request a combined scope covering whichever of these you're using:
#   QuickML.deployment.READ,ZohoCatalyst.cache.READ,ZohoCatalyst.cache.CREATE,
#   ZohoCatalyst.cache.DELETE,ZohoCatalyst.segments.ALL
CATALYST_AUTH=

# Required only when LLM_BACKEND=catalyst_quickml. The exact endpoint
# URL the Catalyst console shows for your deployed QuickML chat
# endpoint (per-model, e.g. .../glm/chat) -- NOT a generic endpoint key.
# For this project's GLM 4.7 Flash deployment:
#   https://api.catalyst.zoho.in/quickml/v1/project/49904000000035007/glm/chat
QUICKML_ENDPOINT_URL=

# Required only when LLM_BACKEND=catalyst_quickml. The model identifier
# the endpoint expects inside the request body (distinct from the URL
# above) -- shown in the console's sample request. For the GLM 4.7
# Flash endpoint this project deployed: crm-di-glm47b_30b_it
QUICKML_MODEL=

# Required for catalyst_quickml and/or RESPONSE_CACHE_BACKEND=catalyst.
# Sent as the CATALYST-ORG header -- Catalyst REST APIs called this way
# fail with ORGID_HEADER_UNAVAILABLE without it. Find it via the
# org/account menu in the Catalyst console (not the same as project_id).
X_ZOHO_CATALYST_ORG_ID=

# Required only when RESPONSE_CACHE_BACKEND=catalyst. Your Catalyst
# project's numeric ID (same value embedded in QUICKML_ENDPOINT_URL
# above, just needed standalone here too).
CATALYST_PROJECT_ID=

# in_memory = per-process cache, single-instance only (default). Currently
# dead code -- conversation history is Postgres-backed
# (ConversationRepository), not cache-backed. Kept for whichever feature
# ends up wanting a fast read-through cache later.
CACHE_BACKEND=in_memory

# "in_memory" (dev default, single-instance only) or "catalyst" -- caches
# read-heavy analytics/sociology/repeat-offender/MO-extraction results,
# since none of that changes until new case data is seeded. Not the same
# concern as CACHE_BACKEND above (that's the older, unused
# conversation-memory var). See infrastructure/cache/cache_provider_factory.py.
RESPONSE_CACHE_BACKEND=catalyst

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Keep true only for local Vite development. In a deployed environment, set
# false and keep CORS_ALLOWED_ORIGINS to the exact trusted frontend URL(s).
CORS_ALLOW_ALL_ORIGINS=true
